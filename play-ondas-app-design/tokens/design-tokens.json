{
  "$schema": "https://design-tokens.org/format",
  "meta": {
    "product": "Play Ondas app",
    "direction": "Aire",
    "version": "1.0.0",
    "description": "Warm, calm, minimal earth palette. Light is default; dark values listed per token."
  },
  "wave": {
    "gamma": { "value": "#D98A2B", "frequency": "30–100 Hz", "meaning": "high cognition" },
    "beta":  { "value": "#CB6A4A", "frequency": "13–30 Hz",  "meaning": "active focus" },
    "alfa":  { "value": "#8C9A56", "frequency": "8–12 Hz",   "meaning": "calm awareness" },
    "theta": { "value": "#6E6CA8", "frequency": "< 8 Hz",    "meaning": "deep relaxation" },
    "brown": { "value": "#9A6B45", "frequency": "—",          "meaning": "brown noise" }
  },
  "color": {
    "bg":          { "light": "#F6F1E8", "dark": "#1C1916" },
    "surface":     { "light": "#FCF9F3", "dark": "#221E19" },
    "list-bg":     { "light": "#FAF6EF", "dark": "#211D18" },
    "border":      { "light": "#E7DECF", "dark": "#332E27" },
    "line":        { "light": "#F0E9DC", "dark": "#2F2A24" },
    "ink":         { "light": "#2C2620", "dark": "#F1EADE" },
    "ink-2":       { "light": "#5F574B", "dark": "#C4BAA9" },
    "mut":         { "light": "#8A7F70", "dark": "#9C917F" },
    "faint":       { "light": "#A2917A", "dark": "#8C8170" },
    "accent":      { "light": "#C77D3A", "dark": "#E0A45C" },
    "accent-text": { "light": "#FFFFFF", "dark": "#1C1916" },
    "track":       { "light": "#E7DECF", "dark": "#332E27" },
    "btn-border":  { "light": "#DCD2C1", "dark": "#3F392F" },
    "knob":        { "light": "#FFFFFF", "dark": "#F1EADE" },
    "dot":         { "light": "#E2D8C6", "dark": "#3A342C" },
    "error":       { "value": "#B4472E" },
    "ok":          { "value": "#5BA17A" }
  },
  "font": {
    "ui":   { "value": "Hanken Grotesk", "fallback": "system-ui, Segoe UI, Roboto, Arial, sans-serif" },
    "mono": { "value": "Space Mono", "fallback": "ui-monospace, Menlo, monospace" }
  },
  "fontSize": {
    "display": { "size": "32px", "weight": 700, "lineHeight": 1.05, "letterSpacing": "-0.02em" },
    "h2":      { "size": "20px", "weight": 700, "lineHeight": 1.2,  "letterSpacing": "-0.01em" },
    "title":   { "size": "17px", "weight": 700, "lineHeight": 1.3 },
    "body":    { "size": "15px", "weight": 400, "lineHeight": 1.55 },
    "body-sm": { "size": "13.5px", "weight": 400, "lineHeight": 1.5 },
    "label":   { "size": "13px", "weight": 400, "lineHeight": 1.4 },
    "caption": { "size": "12px", "weight": 400, "lineHeight": 1.4 },
    "micro":   { "size": "11px", "weight": 400, "lineHeight": 1.4, "font": "mono" },
    "kicker":  { "size": "10.5px", "weight": 700, "lineHeight": 1.2, "letterSpacing": "0.14em", "font": "mono", "transform": "uppercase" }
  },
  "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px", "6": "24px", "7": "30px", "8": "36px" },
  "radius": { "sm": "8px", "md": "11px", "lg": "14px", "xl": "18px", "pill": "999px", "circle": "50%" },
  "shadow": {
    "window":  "0 16px 38px -10px rgba(40,32,20,0.26)",
    "modal":   "0 24px 60px -12px rgba(0,0,0,0.40)",
    "popover": "0 18px 44px -10px rgba(0,0,0,0.45)"
  },
  "motion": {
    "ease": "cubic-bezier(0.4,0,0.2,1)",
    "dur-fast": "120ms",
    "dur-base": "200ms",
    "waveBar": {
      "keyframes": "0%,100% { transform: scaleY(0.30) } 50% { transform: scaleY(1) }",
      "durationRange": "820–1380ms",
      "stagger": "per-bar delay 0–1500ms",
      "easing": "ease-in-out",
      "note": "Animate only while playing; set animation:none when paused."
    }
  },
  "window": { "width": "900px", "height": "620px", "minWidth": "720px", "minHeight": "560px", "listColumnWidth": "316px" }
}
